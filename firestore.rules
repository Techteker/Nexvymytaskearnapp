rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }
    function existing() {
      return resource.data;
    }
    function incoming() {
      return request.resource.data;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      // Only allow listing for leaderboard purposes (client must query for non-banned)
      allow list: if isSignedIn() && existing().isBanned == false && 
                   (!existing().keys().hasAny(['email', 'password', 'googleId']) || isAdmin());
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == 'user' && 
                    incoming().isBanned == false;
      
      allow update: if (isOwner(userId) || isAdmin()) && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'lastLogin', 'quizzes', 'completedTasks', 'coins'])) ||
        isAdmin()
      ) && isValidUser(incoming()) && (incoming().role == existing().role || isAdmin());
      
      function isValidUser(data) {
        return data.email is string && data.email.size() <= 100 &&
               data.name is string && data.name.size() <= 50 &&
               data.coins is number && data.coins >= 0 &&
               data.level is number && data.level >= 0;
      }
    }

    // --- Tasks ---
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      function isValidTask(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.reward is number && data.reward >= 0;
      }
    }

    // --- Submissions ---
    match /submissions/{subId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidSubmission(incoming());
      allow update: if isAdmin();
      
      function isValidSubmission(data) {
        return data.userId == request.auth.uid &&
               data.taskId is string &&
               data.status in ['pending', 'approved', 'rejected'] &&
               data.reward is number;
      }
    }

    // --- Withdrawals ---
    match /withdrawals/{wdrId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidWithdrawal(incoming());
      allow update: if isAdmin();
      
      function isValidWithdrawal(data) {
        return data.userId == request.auth.uid &&
               data.amount is number && data.amount >= 1000 &&
               data.status in ['pending', 'completed', 'failed'];
      }
    }

    // --- Admins ---
    match /admins/{adminUid} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console/backend
    }
  }
}
