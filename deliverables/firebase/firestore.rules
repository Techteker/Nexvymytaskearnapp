rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check authentication state
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to verify user operates on their own record
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper fallback for administrative role permissions
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // User Profile collections Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      // Let Cloud Functions update core credentials like coins streak directly
      allow update: if isAuthenticated() && isOwner(userId) 
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['coins', 'streak', 'referredBy', 'referralCode']);
      allow delete: if isAdmin();

      // Nested documents containing sensitive details (KYC docs)
      match /documents/{docId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
      
      // Transactions log read checks
      match /transactions/{txId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if false; // server-authoritative writing only
      }

      // Check-in calendar statuses
      match /check_ins/{statusId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if false; // server-authoritative daily checks
      }
    }

    // Task and Surveys inventory catalog
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // User Submissions
    match /submissions/{subId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false; // lock results once submitted
      allow delete: if false;
    }

    // Withdrawals Requests rules
    match /withdrawals/{withdrawId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid 
        && request.resource.data.status == 'pending'; // starts as pending
      allow update: if isAdmin(); // only administrators or Cloud Functions handles payments status edits
      allow delete: if false;
    }

    // Referrals tree metrics tracker document
    match /referrals/{refId} {
      allow read: if isAuthenticated() && (resource.data.referrerId == request.auth.uid || resource.data.inviteeId == request.auth.uid);
      allow write: if false; // write operations must remain exclusively transactional via server
    }
  }
}
