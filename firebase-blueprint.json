{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "coins": { "type": "number" },
        "level": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "super_admin"] },
        "isBanned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "coins", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "Earning task",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "reward": { "type": "number" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "active": { "type": "boolean" }
      }
    },
    "Submission": {
      "title": "Submission",
      "description": "Task completion submission",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "proof": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "reward": { "type": "number" }
      }
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "Withdrawal request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Available tasks"
    },
    "/submissions/{subId}": {
      "schema": "Submission",
      "description": "Task submissions"
    },
    "/withdrawals/{wdrId}": {
      "schema": "Withdrawal",
      "description": "Withdrawal requests"
    },
    "/admins/{adminUid}": {
      "schema": { "type": "object", "properties": { "email": { "type": "string" } } },
      "description": "List of authorized admins"
    }
  }
}
